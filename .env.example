# Copy to .env.local and fill in your key (this file is committed; .env.local is NOT).
# A browser Google Maps JS API key. Restrict it by HTTP referrer in Google Cloud
# Console to your dev + Pages origins, e.g.:
#   http://localhost:5193/*
#   https://<your-github-username>.github.io/*
VITE_GOOGLE_MAPS_API_KEY=your-key-here
